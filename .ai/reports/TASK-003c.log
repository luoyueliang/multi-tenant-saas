<?php
namespace MultiTenantSaas\Tests;

use MultiTenantSaas\Models\Permission;
use MultiTenantSaas\Models\Role;
use MultiTenantSaas\Services\RbacService;

class PivotProbeTest extends TestCase
{
    protected function setUp(): void
    {
        parent::setUp();
        Permission::unguarded(function () {
            Permission::create(['permission_id' => 1, 'name' => 'tenant.view', 'display_name' => 'V', 'group' => 'tenant']);
            Permission::create(['permission_id' => 3, 'name' => 'member.view', 'display_name' => 'M', 'group' => 'member']);
        });
    }

    public function test_grant_via_eloquent(): void
    {
        $role = RbacService::createRole(1001, 'probe', 'Probe', '');
        $role->grantPermission(1);
        $role->grantPermission(3);

        $perms = RbacService::getRolePermissions($role->role_id);
        fwrite(STDERR, "DEBUG perms via eloquent grant: " . json_encode($perms) . "\n");
        $this->assertCount(2, $perms);
    }
}
