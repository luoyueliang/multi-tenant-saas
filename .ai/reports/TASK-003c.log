<?php
namespace MultiTenantSaas\Tests;

use Illuminate\Support\Facades\DB;
use MultiTenantSaas\Models\Permission;
use MultiTenantSaas\Models\Role;
use MultiTenantSaas\Services\RbacService;

class PivotProbe2Test extends TestCase
{
    protected function setUp(): void
    {
        parent::setUp();
        Permission::unguarded(function () {
            Permission::create(['permission_id' => 1, 'name' => 'tenant.view', 'display_name' => 'V', 'group' => 'tenant']);
        });
    }

    public function test_probe_pivot_row_after_grant(): void
    {
        $role = RbacService::createRole(1001, 'probe2', 'Probe2', '');
        $role->grantPermission(1);

        $row = DB::table('role_permissions')->where('role_id', $role->role_id)->first();
        fwrite(STDERR, "DEBUG pivot row: " . json_encode($row) . "\n");

        // eager load relation
        $r2 = Role::with('permissions')->find($role->role_id);
        $perm = $r2->permissions->first();
        fwrite(STDERR, "DEBUG eager perm name=" . ($perm ? $perm->name : 'NULL') . " pivot=" . json_encode($perm ? $perm->pivot : null) . "\n");

        // hasPermission
        fwrite(STDERR, "DEBUG hasPermission=" . var_export($role->hasPermission('tenant.view'), true) . "\n");

        // revoke
        $role->revokePermission(1);
        fwrite(STDERR, "DEBUG after revoke count=" . DB::table('role_permissions')->where('role_id', $role->role_id)->count() . "\n");

        $this->assertTrue(true);
    }
}
